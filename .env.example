# Optional: enables the AI portfolio assistant (OpenAI).
# Never commit a real key. For local dev, copy to `.env` in the project root.
#
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Public site URL (https only). Used for canonical + social preview (og:url, og:image).
# On Vercel, this is filled automatically from the deployment URL unless you override it
# (e.g. set to your custom domain for correct link previews).
# VITE_SITE_URL=https://your-portfolio.vercel.app
